{
  "name": "schemaui-web",
  "description": "SchemaUI web interface (offline SPA embedded via include_dir).",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:embedded": "tsc -b && vite build --mode embedded",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
